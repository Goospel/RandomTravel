# ─────────────────────────────────────────────────────────────
# RandomTravel 환경변수 예시 — 이 파일을 `.env.local` 로 복사해 값을 채우세요.
# `.env.local` 은 .gitignore 로 커밋에서 제외됩니다(비밀값 보호).
# ─────────────────────────────────────────────────────────────

# [필수] 한국관광공사 TourAPI 서비스키
#  발급: https://www.data.go.kr → "한국관광공사_국문 관광정보 서비스" 활용신청(무료·자동승인)
#  ⚠️ 반드시 상세페이지의 "일반 인증키(Decoding)" 값을 넣으세요.
#     Encoding 값을 넣으면 이중 인코딩(%252B)으로 키 미등록 오류(code 30)가 납니다.
#  ⚠️ 서버에서만 사용 — NEXT_PUBLIC_ 접두사 금지(붙이면 브라우저에 노출됨)
TOUR_API_KEY=

# [M7부터] ☔ 날씨 필터용 — 기상청 단기예보 조회서비스 서비스키 (같은 포털에서 활용신청)
# WEATHER_API_KEY=

# [M8부터] 🗺️ 내 여행 지도용 — 카카오디벨로퍼스 JavaScript 키
#  이 키만 예외적으로 브라우저 노출 전제(도메인 등록으로 보호) — NEXT_PUBLIC_ 허용
# NEXT_PUBLIC_KAKAO_MAP_KEY=
