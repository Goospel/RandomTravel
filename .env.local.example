# ─────────────────────────────────────────────────────────────
# RandomTravel 환경변수 예시 — 이 파일을 `.env.local` 로 복사해 값을 채우세요.
# `.env.local` 은 .gitignore 로 커밋에서 제외됩니다(비밀값 보호).
# ─────────────────────────────────────────────────────────────

# [필수] 한국관광공사 TourAPI 서비스키
#  발급: https://www.data.go.kr → "한국관광공사_국문 관광정보 서비스" 활용신청(무료·자동승인)
#  ⚠️ 반드시 상세페이지의 "일반 인증키(Decoding)" 값을 넣으세요.
#     Encoding 값을 넣으면 이중 인코딩(%252B)으로 키 미등록 오류(code 30)가 납니다.
#  ⚠️ 서버에서만 사용 — NEXT_PUBLIC_ 접두사 금지(붙이면 브라우저에 노출됨)
TOUR_API_KEY=

# [M7부터] ☔ 날씨 필터용 — 기상청 단기예보 조회서비스 서비스키 (같은 포털에서 활용신청)
# WEATHER_API_KEY=

# [M8] 🗺️ 내 여행 지도용 — 카카오디벨로퍼스 JavaScript 키
#  발급: https://developers.kakao.com → 앱 생성 → [앱 > 플랫폼 키 > JavaScript 키]
#  ⚠️ [제품 설정 > 카카오맵] 사용 설정을 ON 하고, [JavaScript 키 > JavaScript SDK 도메인]에
#     운영 URL과 http://localhost:3456 을 등록해야 지도가 뜹니다(도메인 미등록 시 로드 실패).
#  이 키만 예외적으로 브라우저 노출 전제(도메인 등록으로 보호) — NEXT_PUBLIC_ 허용
NEXT_PUBLIC_KAKAO_MAP_KEY=

# ─────────────────────────────────────────────────────────────
# [M10] 🔐 로그인·동기화 (구글·카카오 OAuth + Neon Postgres) — 전부 서버 전용
# ─────────────────────────────────────────────────────────────

# Auth.js 세션 서명 시크릿 — 아무 랜덤 문자열. 생성: `npx auth secret`
AUTH_SECRET=

# Neon(Postgres) 연결 문자열 — https://neon.tech 프로젝트에서 복사 (postgresql://...)
DATABASE_URL=

# 구글 OAuth — Google Cloud Console > API 및 서비스 > 사용자 인증 정보 > OAuth 웹 클라이언트
#  리디렉션 URI: http://localhost:3456/api/auth/callback/google (+ 운영 URL)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# 카카오 로그인 — M8 지도와 같은 카카오 앱에서 [제품] 카카오 로그인 활성화 후
#  AUTH_KAKAO_ID = REST API 키, AUTH_KAKAO_SECRET = [보안] Client Secret(생성+활성화)
#  리디렉션 URI: http://localhost:3456/api/auth/callback/kakao (+ 운영 URL)
AUTH_KAKAO_ID=
AUTH_KAKAO_SECRET=
